<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             BackgroundColor="#0B160B"
             x:Class="NoteHub_Client.ServerSelectionPage">

    <Grid RowDefinitions="Auto, *, Auto">
        <HorizontalStackLayout Grid.Row="0" HorizontalOptions="Center" Margin="0,40">
            <Image Source="shield_icon.png" HeightRequest="30" WidthRequest="30"/>
            <Label Text="The Sanctuary" FontSize="24" FontAttributes="Bold" TextColor="White" Margin="10,0"/>
        </HorizontalStackLayout>

        <Border Grid.Row="1"
                BackgroundColor="#162616"
                StrokeShape="RoundRectangle 40"
                VerticalOptions="Center"
                HorizontalOptions="Center"
                WidthRequest="350">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,10" Radius="20" Opacity="0.5"/>
            </Border.Shadow>

            <VerticalStackLayout Spacing="20">
                <Label Text="Connect to Vault" 
                       FontSize="32" 
                       TextColor="White" 
                       FontAttributes="Bold" 
                       HorizontalTextAlignment="Center"/>

                <Label Text="Enter your private server address to begin synchronization."
                       TextColor="#A0A0A0"
                       FontSize="16"
                       HorizontalTextAlignment="Center"
                       LineBreakMode="WordWrap"/>

                <VerticalStackLayout Spacing="8" Margin="0,20,0,0">
                    <Label Text="SERVER URL" TextColor="#C6A845" FontSize="12" FontAttributes="Bold"/>

                    <Border StrokeShape="RoundRectangle 15" BackgroundColor="#0E1A0E" Padding="15,5" StrokeThickness="0">
                        <Grid ColumnDefinitions="Auto, *">
                            <Image Source="server_icon.png" HeightRequest="20" Grid.Column="0" Margin="0,0,10,0"/>
                            <Entry Placeholder="https://sanctuary.local:8080" 
                                   PlaceholderColor="#3D533D"
                                   TextColor="White"
                                   FontSize="16"
                                   Grid.Column="1"
                                   Text="{Binding ServerUrl}"/>
                        </Grid>
                    </Border>
                </VerticalStackLayout>

                <!-- TODO: Refactor to use the right color depending on the theme -->
                <Button Text="Continue →"
                        BackgroundColor="{StaticResource Tertiary}"
                        TextColor="{StaticResource White}" 
                        FontSize="18"
                        FontAttributes="Bold"
                        CornerRadius="20"
                        HeightRequest="60"
                        Margin="0,20,0,0"
                        Command="{Binding SubmitServerUrlCommand}"/>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>