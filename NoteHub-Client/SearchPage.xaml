<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NoteHub_Client.SearchPage"
             Title="SearchPage">
    <VerticalStackLayout Padding="10,10" Spacing="30">

        <Editor x:Name="SearchEditor"
                Placeholder="Chercher une note"
                PlaceholderColor="#D1D1D1"
                FontSize="34"
                FontAttributes="Bold"
                TextColor="#1A1A1A"
                AutoSize="TextChanges" 
                BackgroundColor="Transparent" />

        <BoxView HeightRequest="1" Color="#F0F0F0" HorizontalOptions="Fill" />

        <CollectionView x:Name="NotesListView"
                SelectionMode="Single"
                SelectionChanged="OnNoteSelected">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="0,15" RowDefinitions="Auto, Auto">
                        <Label Text="{Binding Title}" 
                       FontSize="18" 
                       FontAttributes="Bold" 
                       TextColor="#1A1A1A" />

                        <Label Grid.Row="1" 
                       Text="{Binding Content}" 
                       FontSize="14" 
                       TextColor="#808080" 
                       MaxLines="1" 
                       LineBreakMode="TailTruncation" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>
</ContentPage>