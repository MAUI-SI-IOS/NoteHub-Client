<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:ctrl="clr-namespace:NoteHub_Client.Views"
             x:Class="NoteHub_Client.WriteNotePage"
             BackgroundColor="White">
    <VerticalStackLayout Padding="10,10" Spacing="20">

        <Label x:Name="ErrorText"
               HeightRequest="1" 
               InputTransparent="True" />

        <Editor
            Placeholder="Titre sans nom"
            Text="{Binding Title}"
            PlaceholderColor="#D1D1D1"
            FontSize="34"
            FontAttributes="Bold"
            TextColor="#1A1A1A"
            AutoSize="TextChanges" 
            BackgroundColor="Transparent" />

        <BoxView HeightRequest="1" Color="#F0F0F0" HorizontalOptions="Fill" />

        <Editor 
            Placeholder="Commencez à écrire votre pensée..."
            Text="{Binding Content}"
            PlaceholderColor="#D1D1D1"
            HeightRequest="400" 
            FontSize="18"
            TextColor="#404040"
            BackgroundColor="Transparent"
            Keyboard="Text" />

        <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
            <Button 
                Text="Save"
                Command="{Binding SaveClickedCommand}"
                CommandParameter="{Binding Source={x:Reference ErrorText}}"
                HeightRequest="40"
                WidthRequest="120"
                BackgroundColor="#D1D1D1"
                CornerRadius="20" />

            <Button 
                Text="New Note"
                Command="{Binding NewNoteCommand}"
                IsVisible="{Binding IsUpdating}"
                HeightRequest="40"
                WidthRequest="120"
                BackgroundColor="#D1D1D1"
                CornerRadius="20" />
        </HorizontalStackLayout>
    </VerticalStackLayout>
</ContentPage>