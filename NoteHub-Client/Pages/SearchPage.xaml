<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:viewmodel="clr-namespace:NoteHub_Client.ViewModels"
             x:DataType="viewmodel:SearchNoteViewModel"
             x:Class="NoteHub_Client.SearchPage"
             Title="SearchPage">
    <VerticalStackLayout Padding="10,10" Spacing="30">
        <Label x:Name="ErrorText"
               HeightRequest="1" 
               InputTransparent="True" />
        <Editor
            Text="{Binding SearchText}"
            Placeholder="Cherchez une note"
            PlaceholderColor="#D1D1D1"
            FontSize="34"
            FontAttributes="Bold"
            TextColor="#1A1A1A"
            AutoSize="TextChanges">
          
        </Editor>

        <BoxView HeightRequest="1" Color="#F0F0F0" HorizontalOptions="Fill" />

        <CollectionView 
            ItemsSource="{Binding List}"
            SelectionMode="Single"
            SelectionChangedCommand="{Binding OnSelectedNoteCommand}"
            SelectionChangedCommandParameter="{Binding SelectedItem, Source={RelativeSource Self}}">
            <!-- if note is empty -->
            <CollectionView.EmptyView>
                <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center">
                    <Label Text="{Binding StatusMessage}"
                           FontSize="18" 
                           TextColor="Gray" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <!-- if note isn't empty -->
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="0,15" RowDefinitions="Auto, Auto">
                        <Label Text="{Binding Title}" 
                       FontSize="18" 
                       FontAttributes="Bold" 
                       TextColor="#1A1A1A" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>
</ContentPage>