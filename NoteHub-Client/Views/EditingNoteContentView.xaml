<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NoteHub_Client.Views.EditingNoteContentView">
    <VerticalStackLayout Padding="10,10" Spacing="30">

        <Editor x:Name="TitleEditor"
                Placeholder="Titre sans nom"
                PlaceholderColor="#D1D1D1"
                FontSize="34"
                FontAttributes="Bold"
                TextColor="#1A1A1A"
                AutoSize="TextChanges" 
                BackgroundColor="Transparent" />

        <BoxView HeightRequest="1" Color="#F0F0F0" HorizontalOptions="Fill" />

        <Editor x:Name="NoteEditor"
                Placeholder="Commencez à écrire votre pensée..."
                PlaceholderColor="#D1D1D1"
                HeightRequest="500" 
                FontSize="18"
                TextColor="#404040"
                BackgroundColor="Transparent"
                Keyboard="Text" />
        <Button 
            x:Name="SaveBtn"
            Text="Save"
            HeightRequest="40"
            WidthRequest="150"
            BackgroundColor="#D1D1D1"
            TextColor="#404040" 
            FontAttributes="Bold"
            FontSize="12"
            CornerRadius="20" 
            Opacity="0.8" 
            VerticalOptions="Center" 
            Margin="0,0,10,0" />

    </VerticalStackLayout>
</ContentView>
