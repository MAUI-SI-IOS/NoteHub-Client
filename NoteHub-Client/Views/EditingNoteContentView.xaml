<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NoteHub_Client.Views.EditingNoteContentView"
             x:Name="root">


    
    <VerticalStackLayout Padding="10,10" Spacing="30">
        <Editor 
            Text="{Binding NoteTitle, Source={x:Reference root}}"
            Placeholder="Titre sans nom"
            PlaceholderColor="#D1D1D1"
            FontSize="34"
            FontAttributes="Bold"
            TextColor="#1A1A1A"
            AutoSize="TextChanges" 
            BackgroundColor="Transparent" />

        <BoxView HeightRequest="1" Color="#F0F0F0" HorizontalOptions="Fill" />

        <Editor 
            Text="{Binding NoteContent, Source={x:Reference root}}"
            Placeholder="Commencez à écrire votre pensée..."
            PlaceholderColor="#D1D1D1"
            HeightRequest="500" 
            FontSize="18"
            TextColor="#404040"
            BackgroundColor="Transparent"
            Keyboard="Text" />
        <FlexLayout Direction="Row" AlignItems="Stretch" JustifyContent="SpaceBetween">
            <Button 
                Text="New Note"
                FlexLayout.Grow="1"
                Margin="0,0,5,0"
                IsVisible="{Binding IsUpdateMode, Source={x:Reference root}}"
                Command="{Binding NewNoteCommand, Source={x:Reference root}}" />

            <Button 
                Text="Save"
                FlexLayout.Grow="1"
                Margin="5,0,0,0"
                Command="{Binding SaveCommand, Source={x:Reference root}}"
                CommandParameter="{Binding Anchor, Source={x:Reference root}}"/>
        </FlexLayout>
    </VerticalStackLayout>
</ContentView>
